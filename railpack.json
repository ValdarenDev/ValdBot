{
  "$schema": "https://schema.railpack.com",
  "steps": {
    "build": {
      "commands": [
        "mkdir -p dist",
        "find . -maxdepth 1 ! -name dist ! -name . -exec cp -R {} dist \\;",
        "cd dist && npm install"
      ]
    }
  },
  "deploy": {
    "inputs": [{ "step": "build" }],
    "startCommand": "npm start",
    "dir": "dist"
  }
}